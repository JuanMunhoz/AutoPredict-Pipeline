# =============================================================================
# AutoPredict-Pipeline — environment configuration
# Copy to `.env` and fill in. NEVER commit the real `.env`.
# All variables are prefixed with APP_ and mapped by pydantic-settings.
# =============================================================================

# --- General --------------------------------------------------------------
APP_ENV=development                 # development | staging | production
APP_LOG_LEVEL=INFO                  # DEBUG | INFO | WARNING | ERROR
APP_LOG_JSON=false                  # true in production for structured logs

# --- Assets / target ------------------------------------------------------
APP_ASSETS=BTC,SOL                  # comma-separated list of assets to model
APP_PREDICTION_HORIZON_HOURS=4      # forecast horizon
APP_OHLCV_INTERVAL=1h               # candle interval used to build features

# --- Data providers -------------------------------------------------------
APP_COINGECKO_BASE_URL=https://api.coingecko.com/api/v3
APP_BINANCE_BASE_URL=https://api.binance.com
APP_FEAR_GREED_BASE_URL=https://api.alternative.me
APP_ALPHAVANTAGE_API_KEY=           # optional
APP_HTTP_TIMEOUT_SECONDS=15
APP_HTTP_MAX_RETRIES=4

# --- Storage (DVC remote / Supabase S3-compatible) ------------------------
APP_S3_ENDPOINT_URL=https://<project-ref>.supabase.co/storage/v1/s3
APP_S3_BUCKET=autopredict
APP_S3_REGION=us-east-1
AWS_ACCESS_KEY_ID=                  # Supabase storage access key
AWS_SECRET_ACCESS_KEY=              # Supabase storage secret key

# --- MLflow ---------------------------------------------------------------
MLFLOW_TRACKING_URI=http://localhost:5000
APP_MLFLOW_EXPERIMENT=autopredict
APP_MODEL_REGISTRY_STAGE=Production

# --- Model promotion gate -------------------------------------------------
APP_MIN_ROC_AUC=0.55                # minimum AUC to be promotable at all
APP_MIN_ACCURACY=0.52
APP_PROMOTION_IMPROVEMENT=0.005     # new model must beat prod AUC by this margin

# --- API ------------------------------------------------------------------
APP_API_HOST=0.0.0.0
APP_API_PORT=8000
APP_MODEL_DIR=models                # local dir where the served model lives
